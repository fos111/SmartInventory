                  "    pm.expect(jsonData.data.length).to.be.greaterThan(0);",
                  "});",
                  "if (jsonData.data && jsonData.data.length > 0) {",
                  "    pm.collectionVariables.set(\"userId\", jsonData.data[0].id);",
                  "}"
                ],
