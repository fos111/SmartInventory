# =============================================================================
# SmartInventory Environment Variables
# =============================================================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
# WARNING: .env is gitignored. Never commit real credentials.
# =============================================================================

# --- Email (SMTP / Mailtrap) ---
SMTP_USERNAME=your-mailtrap-username
SMTP_PASSWORD=your-mailtrap-password

# --- MQTT / HiveMQ Cloud ---
# IoT Location Service connects to HiveMQ Cloud on startup.
# TLS port 8883 (MQTTS), topic: iot/location
HIVEMQ_USERNAME=your-hivemq-username
HIVEMQ_PASSWORD=your-hivemq-password
